# Environment Configuration

# Public contact form settings
# Optional: add a Cloudflare Turnstile site key to show a CAPTCHA challenge in the form
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# Server-side contact delivery settings
# Set these in Netlify/Vercel project environment variables, not in client code
# CONTACT_TO_EMAIL=vaibhav@example.com
# CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
# RESEND_API_KEY=re_xxxxxxxxx
# Optional: enable server-side Turnstile verification
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# LinkedIn URL
VITE_LINKEDIN_URL=https://linkedin.com/in/vaibhavpathak

# Resume URL (if hosted externally)
VITE_RESUME_URL=https://example.com/resume.pdf

# Optional: Analytics
# VITE_GA_ID=G-XXXXXXXXXX
